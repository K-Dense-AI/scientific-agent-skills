# ── WhatsApp Cloud API ──
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=my-secret-token
WHATSAPP_RECIPIENT_PHONE=

# ── LLM Providers ──
LLM_DEFAULT_PROVIDER=gemini          # claude | openai | gemini
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GEMINI_API_KEY=

# ── Voice Transcription ──
TRANSCRIPTION_PROVIDER=openai        # openai | groq | deepgram
GROQ_API_KEY=
DEEPGRAM_API_KEY=

# ── Tools ──
SERPER_API_KEY=
GOOGLE_CALENDAR_CREDENTIALS=         # path to OAuth credentials.json
NOTION_INTEGRATION_SECRET=
NOTION_DATABASE_ID=

# ── Storage ──
DATABASE_PATH=data/rayban.db

# ── MCP Server ──
MCP_SERVER_PORT=8080

# ── Optional: TTS ──
TTS_ENABLED=false
TTS_PROVIDER=openai                  # openai | elevenlabs
ELEVENLABS_API_KEY=
